# Copy to .env (gitignored) and fill in.

# --- Postgres ---
# These are consumed by both the app and the postgres container in docker-compose.
POSTGRES_USER=mtg
POSTGRES_PASSWORD=change-me-to-a-long-random-string
POSTGRES_DB=mtg
# Connection string the app uses. Inside docker-compose the host is the service
# name `postgres`; for local dev against a local postgres use localhost.
DATABASE_URL=postgres://mtg:change-me-to-a-long-random-string@postgres:5432/mtg

# --- App ---
PORT=8477
HOST=0.0.0.0
# Secret used to sign session cookies. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change-me-to-a-64-char-hex-secret
# The first time the server boots with no users, it creates an admin account
# with this username/password so you can log in and provision the kids.
ADMIN_USERNAME=jason
ADMIN_PASSWORD=change-me-first-login
# Optional shared invite code that lets new accounts self-register. Leave blank
# to disable self-registration entirely (admin provisions all accounts).
INVITE_CODE=

# Where downloaded card art is cached on disk (inside the container).
IMAGE_CACHE_DIR=/data/image-cache

# --- Cloudflare Tunnel (public access at mtg.jsb-emr.us) ---
# Per-tunnel JWT from Cloudflare Zero Trust → Tunnels → (tunnel) → connector.
# NOT a Cloudflare account API token. Leave blank to run LAN-only.
TUNNEL_TOKEN=
